@model RecipeSite.Models.Recipe

@{
    ViewData["Title"] = "Видалення рецепта";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 p-4" style="border-radius: 16px;">
                <div class="text-center text-danger mb-3">
                    <span style="font-size: 4rem;">🗑</span>
                    <h2 class="fw-bold mt-2">Видалити рецепт?</h2>
                    <p class="text-muted">Ви впевнені, що хочете назавжди видалити цей рецепт? Разом з ним видаляться і всі його інгредієнти. Цю дію неможливо скасувати.</p>
                </div>

                <hr />

                <div class="bg-light p-3 rounded-3 mb-4 text-center">
                    <h4 class="fw-bold text-dark mb-1">@Model.Title</h4>
                    <span class="badge bg-secondary">⏱ @Model.CookingTime хвилин</span>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="RecipeId" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg fw-bold shadow-sm">Так, видалити назавжди</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg fw-bold mt-1">Ні, скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>