@model RecipeSite.Models.Recipe

@{
    ViewData["Title"] = "Перегляд рецепта";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-success mb-0">@Model.Title</h1>
        <div class="d-flex justify-content-end gap-2 mb-4">
    @if (User.Identity.IsAuthenticated)
    {
        <a asp-action="Edit" asp-route-id="@Model.RecipeId" class="btn btn-warning fw-bold px-4">Редагувати</a>
    }
    <a asp-action="Index" class="btn btn-outline-secondary px-4">Повернутися до списку</a>
</div>
    </div>

    <div class="row">
        <div class="col-md-7">
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; overflow: hidden;">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" class="img-fluid" alt="@Model.Title" style="width: 100%; max-height: 400px; object-fit: cover;" />
                }
                else
                {
                    <div class="bg-light text-center py-5 text-muted" style="min-height: 250px; d-flex: flex; flex-direction: column; align-items: center; justify-content: center;">
                        <span style="font-size: 3.5rem;">🍽</span>
                        <p class="mt-2 mb-0 class="text-muted"">Фотографії для цієї страви ще не додано</p>
                    </div>
                }
                <div class="card-body p-4">
                    <h4 class="fw-bold text-secondary mb-3">📖 Інструкція / Опис страви</h4>
                    <p class="card-text fs-5 text-dark" style="white-space: pre-line; line-height: 1.6;">@Model.Description</p>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm border-0 mb-4 bg-light" style="border-radius: 12px;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <span class="fs-5 fw-bold text-muted">Час приготування:</span>
                    <span class="badge bg-success fs-5 px-3 py-2 rounded-pill">⏱ @Model.CookingTime хвилин</span>
                </div>
            </div>

            <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0 fw-bold">🛒 Склад рецепта</h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.RecipeIngredients != null && Model.RecipeIngredients.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.RecipeIngredients)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-bottom">
                                    <span class="fs-5 text-dark fw-medium">@item.Ingredient.Name</span>
                                    <span class="badge bg-light text-success border border-success rounded-pill fs-6 px-3 py-2">@item.Amount @item.Unit</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            Інгредієнти для цього рецепта не вказані.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>