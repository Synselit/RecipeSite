@model RecipeSite.Models.Recipe

@{
    ViewData["Title"] = "Новий рецепт";
}

<h1 class="mb-4">Додати новий рецепт</h1>

<form asp-action="Create" enctype="multipart/form-data">
    <div class="row">
        <div class="col-md-5">
            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-bold">Назва страви</label>
                <input asp-for="Title" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">Опис</label>
                <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="CookingTime" class="form-label fw-bold">Час (хвилин)</label>
                <input asp-for="CookingTime" type="number" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Фото страви</label>
                <input type="file" name="uploadFile" class="form-control" accept="image/*" />
            </div>
        </div>

        <div class="col-md-7 border-start">
            <h5 class="mb-3">Склад (Інгредієнти)</h5>
            
            <div id="ingredients-container"></div>
            
            <button type="button" class="btn btn-outline-success mt-2" onclick="addIngredientRow()">+ Додати ще інгредієнт</button>
        </div>
    </div>

    <hr class="my-4" />
    <input type="submit" value="Зберегти рецепт" class="btn btn-primary btn-lg" />
    <a asp-action="Index" class="btn btn-secondary btn-lg ms-2">Скасувати</a>
</form>

<template id="ingredientTemplate">
    <div class="row mb-2">
        <div class="col-md-5">
            <input type="text" name="ingredientNames" class="form-control" placeholder="Назва (напр. Молоко)" required />
        </div>
        <div class="col-md-3">
            <input type="number" name="amounts" class="form-control" step="0.1" placeholder="Кількість" required />
        </div>
        <div class="col-md-3">
            <input type="text" name="units" class="form-control" placeholder="г, шт..." required />
        </div>
        <div class="col-md-1">
            <button type="button" class="btn btn-danger w-100" onclick="this.parentElement.parentElement.remove()" title="Видалити">✖</button>
        </div>
    </div>
</template>

@section Scripts {
    <script>
        function addIngredientRow() {
            const container = document.getElementById('ingredients-container');
            const template = document.getElementById('ingredientTemplate');
            const clone = template.content.cloneNode(true);
            container.appendChild(clone);
        }
        window.onload = addIngredientRow;
    </script>
}