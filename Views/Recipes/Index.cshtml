@model IEnumerable<RecipeSite.Models.Recipe>

@{
    ViewData["Title"] = "Всі рецепти";
}

<h1 class="mb-4">Мої рецепти</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Додати новий рецепт</a>
</p>

<table class="table table-bordered table-hover mt-3 align-middle">
    <thead class="table-dark">
        <tr>
            <th>Фото</th>
            <th>Назва страви</th>
            <th>Час приготування (хв)</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td style="width: 100px; text-align: center;">
                    @if (!string.IsNullOrEmpty(item.ImagePath))
                    {
                        <img src="@item.ImagePath" alt="@item.Title" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;" />
                    }
                    else
                    {
                        <span class="text-muted small">Немає фото</span>
                    }
                </td>
                <td class="fw-bold">@item.Title</td>
                <td>@item.CookingTime</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.RecipeId" class="btn btn-sm btn-info">Деталі</a>
                    <a asp-action="Edit" asp-route-id="@item.RecipeId" class="btn btn-sm btn-warning">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@item.RecipeId" class="btn btn-sm btn-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>