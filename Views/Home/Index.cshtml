@model IEnumerable<RecipeSite.Models.Recipe>

@{
    ViewData["Title"] = "Головна";
}

<div class="text-center my-5 py-4 bg-light rounded-3 shadow-sm">
    <h1 class="display-4 fw-bold text-success">Світ Рецептів</h1>
    <p class="lead text-muted">Рецепти для всіх і кожного</p>
    <a asp-controller="Recipes" asp-action="Create" class="btn btn-success btn-lg px-4 mt-2 shadow-sm">Додати свій рецепт</a>
</div>

<div class="container mb-5">
    <h2 class="mb-4 fw-bold text-secondary"> Нові рецепти на сайті</h2>
    
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center my-5">
                <p class="text-muted fs-5">У базі поки немає жодної страви. Станьте першим розробником-поваром! </p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 bg-white" style="border-radius: 12px; overflow: hidden; transition: transform 0.2s;">
                        <div style="height: 220px; width: 100%; overflow: hidden; background-color: #f8f9fa;">
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="@item.ImagePath" class="w-100 h-100" style="object-fit: cover;" alt="@item.Title" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                                    <span class="fs-4">🍽</span>
                                    <span class="small mt-1">Немає фото</span>
                                </div>
                            }
                        </div>
                        
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title fw-bold text-dark mb-2">@item.Title</h5>
                            <p class="card-text text-muted flex-grow-1 text-truncate" style="max-height: 48px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; white-space: normal;">
                                @item.Description
                            </p>
                            
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                                <span class="badge bg-light text-dark border p-2">⏱ @item.CookingTime хв</span>
                                <a asp-controller="Recipes" asp-action="Details" asp-route-id="@item.RecipeId" class="btn btn-sm btn-success px-3" style="border-radius: 6px;">Переглянути</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>